---
import Layout from '../layouts/Layout.astro';
---

<Layout title="SEO für Anwälte Basel: Mehr Mandanten durch Google | RelayStack">

	<!-- Navigation -->
	<header class="fixed top-0 left-0 right-0 z-50 bg-[#111111]/95 backdrop-blur-md border-b border-[#222]">
		<div class="max-w-6xl mx-auto px-6 py-4 flex justify-between items-center">
			<a href="/" class="text-xl font-bold tracking-tight">
				<span class="text-white">relay</span><span class="text-orange-600">stack</span>
			</a>
			<nav class="hidden md:flex gap-6 text-sm">
				<a href="/" class="text-[#888] hover:text-white">Startseite</a>
				<a href="#pain" class="text-[#888] hover:text-white">Probleme</a>
				<a href="#loesung" class="text-[#888] hover:text-white">Lösung</a>
				<a href="#rechner" class="text-[#888] hover:text-white">ROI</a>
				<a href="#preise" class="text-[#888] hover:text-white">Preise</a>
			</nav>
			<a href="https://calendly.com/relaystack/15min" class="px-5 py-2.5 bg-blue-600 text-white text-sm font-semibold rounded-lg hover:bg-blue-700">Gratis Analyse buchen</a>
		</div>
	</header>

	<!-- 2026 Breadcrumb Navigation -->
	<nav aria-label="Breadcrumb" class="pt-20 pb-4 bg-[#111111]">
		<div class="max-w-6xl mx-auto px-6">
			<ol class="flex items-center gap-2 text-sm text-[#666]" itemscope itemtype="https://schema.org/BreadcrumbList">
				<li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
					<a href="/" itemprop="item" class="hover:text-blue-500 transition-colors">
						<span itemprop="name">Startseite</span>
					</a>
					<meta itemprop="position" content="1" />
				</li>
				<li class="text-[#444]">/</li>
				<li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
					<span itemprop="name" class="text-blue-500">Anwälte</span>
					<meta itemprop="position" content="2" />
				</li>
			</ol>
		</div>
	</nav>

	<!-- Hero Section -->
	<section class="min-h-[85vh] flex items-center pt-24 pb-16">
		<div class="max-w-4xl mx-auto px-6 text-center">
			<span class="inline-block px-4 py-2 bg-blue-600/20 text-blue-400 text-sm font-medium rounded-full mb-6">
			 für Anwälte und Kanzleien
			</span>
			
			<h1 class="text-4xl md:text-5xl font-bold leading-tight mb-6">
				<span class="text-white">67% der Mandanten suchen zuerst bei Google.</span><br/>
				<span class="text-blue-500">Nur die Kanzleien auf Seite 1 bekommen sie.</span>
			</h1>
			
			<p class="text-lg text-[#999] max-w-2xl mx-auto mb-8 leading-relaxed">
				97% der Rechtssuchenden googeln vor der Kontaktaufnahme. CPC für Rechtsbegriffe kostet CHF 15-45. SEO ist 10x günstiger und nachhaltiger. 
			</p>
			
			<div class="flex flex-col sm:flex-row gap-4 justify-center mb-10">
				<a href="https://calendly.com/relaystack/15min" class="px-8 py-4 bg-blue-600 text-white font-semibold rounded-lg hover:bg-blue-700 transition-all hover:scale-105 text-lg">
					Kostenlose Analyse buchen
				</a>
				<a href="#loesung" class="px-8 py-4 border-2 border-blue-600 text-blue-500 font-semibold rounded-lg hover:bg-blue-600 hover:text-white transition-all">
					So funktioniert es
				</a>
			</div>
			
			<!-- Trust Stats -->
			<div class="grid grid-cols-3 gap-4 max-w-xl mx-auto">
				<div class="bg-[#1a1a1a] p-4 rounded-lg">
					<p class="text-2xl font-bold text-blue-500">20+</p>
					<p class="text-xs text-[#666]">Kanzleien optimiert</p>
				</div>
				<div class="bg-[#1a1a1a] p-4 rounded-lg">
					<p class="text-2xl font-bold text-blue-500">3x</p>
					<p class="text-xs text-[#666]">Mehr Anfragen</p>
				</div>
				<div class="bg-[#1a1a1a] p-4 rounded-lg">
					<p class="text-2xl font-bold text-blue-500">120T</p>
					<p class="text-xs text-[#666]">Seite-1 Garantie</p>
				</div>
			</div>
		</div>
	</section>

	<!-- Pain Points Section -->
	<section id="pain" class="py-24 bg-[#151515]">
		<div class="max-w-4xl mx-auto px-6">
			<div class="text-center mb-16">
				<p class="text-sm text-blue-600 font-medium mb-2">DAS PROBLEM</p>
				<h2 class="text-4xl font-bold text-white mb-4">Warum gute Kanzleien Mandanten verlieren</h2>
			</div>
			
			<div class="space-y-6">
				<div class="bg-[#1a1a1a] p-6 rounded-xl border border-[#333]">
					<h3 class="text-lg font-semibold text-white mb-2">1. Mandanten googeln vorher, nicht danach</h3>
					<p class="text-[#888]">67% der Mandanten recherchieren online BEVOR sie Freunde fragen. Wer nicht auf Seite 1 ist, existiert nicht für sie.</p>
				</div>
				
				<div class="bg-[#1a1a1a] p-6 rounded-xl border border-[#333]">
					<h3 class="text-lg font-semibold text-white mb-2">2. Konkurrenz in Featured Snippets</h3>
					<p class="text-[#888]">Ihre Konkurrenz mit FAQ-Schema erscheint in Featured Snippets. "Wie viel kostet ein Anwalt?" wird von Ihrem Konkurrenten beantwortet.</p>
				</div>
				
				<div class="bg-[#1a1a1a] p-6 rounded-xl border border-[#333]">
					<h3 class="text-lg font-semibold text-white mb-2">3. CPC CHF 15-45 pro Klick ist ruinous</h3>
					<p class="text-[#888]">Google Ads für Rechtsbegriffe kostet CHF 15-45 pro Klick. Organic SEO ist 10x wertvoller und nachhaltig.</p>
				</div>
				
				<div class="bg-[#1a1a1a] p-6 rounded-xl border border-[#333]">
					<h3 class="text-lg font-semibold text-white mb-2">4. Fehlende kantonsspezifische Inhalte</h3>
					<p class="text-[#888]">Ein einziger Standortseite für 10+ Städte. Keine lokalisierten Inhalte für Basel, Bern oder Zürich.</p>
				</div>
				
				<div class="bg-[#1a1a1a] p-6 rounded-xl border border-[#333]">
					<h3 class="text-lg font-semibold text-white mb-2">5. Ladezeiten über 8 Sekunden</h3>
					<p class="text-[#888]">Ihre Website braucht 8+ Sekunden auf dem Handy. 60% der legal Suchen sind mobile. Mandanten gehen zur nächsten Kanzlei.</p>
				</div>
			</div>
		</div>
	</section>

	<!-- Cost of Inaction -->
	<section class="py-16 bg-[#111]">
		<div class="max-w-3xl mx-auto px-6">
			<div class="bg-[#1a1a1a] p-8 rounded-xl border border-[#333]">
				<h3 class="text-xl font-bold text-white mb-6 text-center">Was kostet eine unsichtbare Kanzlei?</h3>
				<div class="grid md:grid-cols-2 gap-6">
					<div>
						<label class="block text-sm text-[#888] mb-2">Durchschnittlicher Mandantenumsatz (CHF)</label>
						<input type="number" id="avgCase" value="3500" class="w-full px-4 py-3 bg-[#222] border border-[#444] rounded-lg text-white" onchange="calculateCostLaw()" />
					</div>
					<div>
						<label class="block text-sm text-[#888] mb-2">Verlorene Mandanten/Monat</label>
						<input type="number" id="lostClients" value="3" class="w-full px-4 py-3 bg-[#222] border border-[#444] rounded-lg text-white" onchange="calculateCostLaw()" />
					</div>
				</div>
				<div class="mt-6 p-4 bg-red-900/20 rounded-lg border border-red-500/30">
					<p class="text-red-400 font-semibold">Sie verlieren monatlich: <span id="monthlyCostLaw" class="text-2xl">CHF 10'500</span></p>
					<p class="text-sm text-[#666] mt-2">Ein einziger Mandat deckt die gesamte Investition. Jeder weitere ist reiner Gewinn.</p>
				</div>
			</div>
			
			<script>
				function calculateCostLaw() {
					const avgCase = parseFloat(document.getElementById('avgCase').value) || 3500;
					const lostClients = parseFloat(document.getElementById('lostClients').value) || 3;
					
					const monthly = avgCase * lostClients;
					document.getElementById('monthlyCostLaw').textContent = 'CHF ' + monthly.toLocaleString();
				}
			</script>
		</div>
	</section>

	<!-- Solution Process -->
	<section id="loesung" class="py-24">
		<div class="max-w-5xl mx-auto px-6">
			<div class="text-center mb-16">
				<p class="text-sm text-blue-600 font-medium mb-2">MEINE METHODE</p>
				<h2 class="text-4xl font-bold text-white mb-4">4 Schritte zu mehr Mandanten</h2>
			</div>
			
			<div class="space-y-8">
				<!-- Step 1 -->
				<div class="flex flex-col md:flex-row gap-8 items-start">
					<div class="w-16 h-16 bg-blue-600 rounded-2xl flex items-center justify-center shrink-0">
						<span class="text-white text-2xl font-bold">1</span>
					</div>
					<div class="flex-1">
						<h3 class="text-xl font-bold text-white mb-3">Analyse und Strategie</h3>
						<p class="text-[#888] mb-4">Ich analysiere Ihre Kanzlei und Konkurrenz. Sie erhalten einen 15-minütigen Bericht mit:</p>
						<ul class="space-y-2 text-[#ccc]">
							<li class="flex items-start gap-2"><span class="text-green-500">✓</span> SEO-Score (0-100) für Ihre Website</li>
							<li class="flex items-start gap-2"><span class="text-green-500">✓</span> Die Top-Keywords Ihrer Konkurrenz</li>
							<li class="flex items-start gap-2"><span class="text-green-500">✓</span> Technische Probleme und Ladezeiten</li>
							<li class="flex items-start gap-2"><span class="text-green-500">✓</span> Konkrete Empfehlungen für Ihre Fachgebiete</li>
						</ul>
					</div>
				</div>
				
				<!-- Step 2 -->
				<div class="flex flex-col md:flex-row gap-8 items-start">
					<div class="w-16 h-16 bg-blue-600 rounded-2xl flex items-center justify-center shrink-0">
						<span class="text-white text-2xl font-bold">2</span>
					</div>
					<div class="flex-1">
						<h3 class="text-xl font-bold text-white mb-3">Google Business und E-E-A-T</h3>
						<p class="text-[#888] mb-4">Google bewertet Expertise, Autorität und Vertrauen. Ich optimiere:</p>
						<ul class="space-y-2 text-[#ccc]">
							<li class="flex items-start gap-2"><span class="text-green-500">✓</span> Vollständiges Kanzlei-Profil mit Zulassungen</li>
							<li class="flex items-start gap-2"><span class="text-green-500">✓</span> Fachanwalts-Status und Spezialisierungen</li>
							<li class="flex items-start gap-2"><span class="text-green-500">✓</span> Autoritative Inhalte zu Ihren Rechtsgebieten</li>
							<li class="flex items-start gap-2"><span class="text-green-500">✓</span> Schema-Markup für Anwälte</li>
						</ul>
					</div>
				</div>
				
				<!-- Step 3 -->
				<div class="flex flex-col md:flex-row gap-8 items-start">
					<div class="w-16 h-16 bg-blue-600 rounded-2xl flex items-center justify-center shrink-0">
						<span class="text-white text-2xl font-bold">3</span>
					</div>
					<div class="flex-1">
						<h3 class="text-xl font-bold text-white mb-3">Website-Optimierung</h3>
						<p class="text-[#888] mb-4">Für Keywords wie "Arbeitsrecht Anwalt Basel" optimiert:</p>
						<ul class="space-y-2 text-[#ccc]">
							<li class="flex items-start gap-2"><span class="text-green-500">✓</span> Separate Seiten für jedes Fachgebiet und Kanton</li>
							<li class="flex items-start gap-2"><span class="text-green-500">✓</span> Mobile-First (60% suchen auf dem Handy)</li>
							<li class="flex items-start gap-2"><span class="text-green-500">✓</span> Kontaktformular für Sofortanfragen</li>
							<li class="flex items-start gap-2"><span class="text-green-500">✓</span> FAQ für häufige Fragen</li>
						</ul>
					</div>
				</div>
				
				<!-- Step 4 -->
				<div class="flex flex-col md:flex-row gap-8 items-start">
					<div class="w-16 h-16 bg-blue-600 rounded-2xl flex items-center justify-center shrink-0">
						<span class="text-white text-2xl font-bold">4</span>
					</div>
					<div class="flex-1">
						<h3 class="text-xl font-bold text-white mb-3">Content-Strategie</h3>
	003cp class="text-[#888] mb-4">Autorität durch Inhalte:</p>
						<ul class="space-y-2 text-[#ccc]">
							<li class="flex items-start gap-2"><span class="text-green-500">✓</span> Rechtliche Ratgeber für Mandanten</li>
							<li class="flex items-start gap-2"><span class="text-green-500">✓</span> Updates zu Gesetzesänderungen</li>
							<li class="flex items-start gap-2"><span class="text-green-500">✓</span> 3 Monate Support inklusive</li>
						</ul>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- ROI Calculator -->
	<section id="rechner" class="py-24 bg-[#151515]">
		<div class="max-w-3xl mx-auto px-6">
			<div class="text-center mb-12">
				<p class="text-sm text-blue-600 font-medium mb-2">ROI RECHNER</p>
				<h2 class="text-4xl font-bold text-white">Ein Mandat deckt die Investition</h2>
			</div>
			
			<div class="bg-[#1a1a1a] p-8 rounded-xl border border-[#333]">
				<div class="grid md:grid-cols-2 gap-8 mb-8">
					<div>
						<label class="block text-sm text-[#888] mb-2">Durchschnittlicher Mandantenumsatz (CHF)</label>
						<input type="number" id="avgCase" value="3500" class="w-full px-4 py-3 bg-[#222] border border-[#444] rounded-lg text-white" onchange="calculateROILaw()" />
					</div>
					<div>
						<label class="block text-sm text-[#888] mb-2">Zusätzliche Mandanten pro Monat</label>
						<input type="number" id="newClients" value="5" class="w-full px-4 py-3 bg-[#222] border border-[#444] rounded-lg text-white" onchange="calculateROILaw()" />
					</div>
				</div>
				
				<div class="border-t border-[#333] pt-6">
					<div class="flex justify-between items-center mb-2">
						<span class="text-[#888]">Zusätzlicher Umsatz pro Monat:</span>
						<span id="monthlyRevenueLaw" class="text-2xl font-bold text-green-500">CHF 17'500</span>
					</div>
					<div class="flex justify-between items-center mb-2">
						<span class="text-[#888]">Zusätzlicher Umsatz pro Jahr:</span>
						<span id="yearlyRevenueLaw" class="text-2xl font-bold text-green-500">CHF 210'000</span>
					</div>
					<div class="flex justify-between items-center">
						<span class="text-[#888]">Ihre Investition:</span>
						<span class="text-xl font-bold text-blue-500">CHF 3'900 einmalig</span>
					</div>
				</div>
				
				<div class="mt-6 p-4 bg-green-600/20 rounded-lg border border-green-600/30">
					<p class="text-green-400 font-semibold">ROI: <span id="roiValueLaw">5285%</span> im ersten Jahr</p>
				</div>
			</div>
			
			<script>
				function calculateROILaw() {
					const avgCase = parseFloat(document.getElementById('avgCase').value) || 3500;
					const newClients = parseFloat(document.getElementById('newClients').value) || 5;
					const investment = 3900;
					
					const monthly = avgCase * newClients;
					const yearly = monthly * 12;
					const roi = Math.round(((yearly - investment) / investment) * 100);
					
					document.getElementById('monthlyRevenueLaw').textContent = 'CHF ' + monthly.toLocaleString();
					document.getElementById('yearlyRevenueLaw').textContent = 'CHF ' + yearly.toLocaleString();
					document.getElementById('roiValueLaw').textContent = roi + '%';
				}
			</script>
		</div>
	</section>

	<!-- Pricing -->
	<section id="preise" class="py-24">
		<div class="max-w-4xl mx-auto px-6">
			<div class="text-center mb-12">
				<p class="text-sm text-blue-600 font-medium mb-2">PREISE</p>
				<h2 class="text-4xl font-bold text-white">Transparente Investition</h2>
			</div>
			
			<div class="grid md:grid-cols-2 gap-6">
				<div class="bg-[#1a1a1a] p-8 rounded-xl border border-[#333]">
					<div class="inline-block px-3 py-1 bg-blue-600/20 text-blue-400 text-xs font-medium rounded-full mb-4">Für bestehende Kanzleien</div>
					<h3 class="text-lg font-semibold text-white">Legal SEO Boost</h3>
					<div class="mt-4 mb-2">
						<span class="text-3xl font-bold text-white">CHF 990</span>
					</div>
					<p class="text-xs text-[#555]">Einmalig, 2 Wochen Support</p>
					<ul class="mt-6 space-y-2 text-sm text-[#888]">
						<li>✓ Google Business Profil Optimierung</li>
						<li>✓ E-E-A-T Optimierung</li>
						<li>✓ Technisches SEO-Audit</li>
						<li>✓ Schema-Markup für Anwälte</li>
						<li>✓ Keyword-Recherche</li>
					</ul>
					<a href="https://calendly.com/relaystack/15min" class="block mt-6 w-full px-4 py-3 border border-[#444] text-[#ccc] text-center text-sm font-semibold rounded-lg hover:border-blue-600 hover:text-blue-500 transition-all">Beratung buchen</a>
				</div>
				
				<div class="bg-[#111] p-8 rounded-xl border-2 border-blue-600 relative">
					<span class="absolute -top-3 left-1/2 -translate-x-1/2 px-4 py-1 bg-blue-600 text-white text-xs font-bold rounded-full">BELIEBTESTE</span>
					<div class="inline-block px-3 py-1 bg-blue-600/20 text-blue-400 text-xs font-medium rounded-full mb-4">Komplettlösung</div>
					<h3 class="text-lg font-semibold text-white">Kanzlei Pro</h3>
					<div class="mt-4 mb-2">
						<span class="text-3xl font-bold text-white">CHF 3'900</span>
					</div>
					<p class="text-xs text-green-500">oder CHF 390/Monat x 10</p>
					<ul class="mt-6 space-y-2 text-sm text-[#ccc]">
						<li>✓ Alles aus Legal SEO Boost</li>
						<li>✓ Professionelle Website (5-7 Seiten)</li>
						<li>✓ Kontaktformular für Sofortanfragen</li>
						<li>✓ Fachgebiet-spezifische Seiten</li>
						<li>✓ 120-Tage Seite-1-Garantie</li>
					</ul>
					<a href="https://calendly.com/relaystack/15min" class="block mt-6 w-full px-4 py-3 bg-blue-600 text-white text-center text-sm font-bold rounded-lg hover:bg-blue-700 transition-all">Jetzt buchen</a>
				</div>
			</div>
		</div>
	</section>

	<!-- FAQ -->
	<section class="py-24 bg-[#151515]">
		<div class="max-w-3xl mx-auto px-6">
			<div class="text-center mb-12">
				<p class="text-sm text-blue-600 font-medium mb-2">FAQ</p>
				<h2 class="text-3xl font-bold text-white">Häufige Fragen</h2>
			</div>
			
			<div class="space-y-4">
				<div class="bg-[#1a1a1a] rounded-xl border border-[#333] overflow-hidden">
					<button class="w-full px-6 py-4 text-left flex justify-between items-center" onclick="this.nextElementSibling.classList.toggle('hidden')">
						<span class="font-medium text-white">Ist SEO für Anwälte ethisch?</span>
						<svg class="w-5 h-5 text-[#666]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
					</button>
					<div class="px-6 pb-4 hidden">
						<p class="text-[#888]">Ja, ich arbeite nach den Richtlinien der Schweizer Anwaltskammer. Faktische Informationen, keine Werbeversprechen. Alle Inhalte werden von Ihnen freigegeben.</p>
					</div>
				</div>
				
				<div class="bg-[#1a1a1a] rounded-xl border border-[#333] overflow-hidden">
					<button class="w-full px-6 py-4 text-left flex justify-between items-center" onclick="this.nextElementSibling.classList.toggle('hidden')">
						<span class="font-medium text-white">Wie lange dauert es?</span>
						<svg class="w-5 h-5 text-[#666]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
					</button>
					<div class="px-6 pb-4 hidden">
						<p class="text-[#888]">Erste Ergebnisse nach 4-8 Wochen. Ich garantiere Seite-1-Platzierung für Ihre Top-Keywords innerhalb von 120 Tagen.</p>
					</div>
				</div>
				
				<div class="bg-[#1a1a1a] rounded-xl border border-[#333] overflow-hidden">
					<button class="w-full px-6 py-4 text-left flex justify-between items-center" onclick="this.nextElementSibling.classList.toggle('hidden')">
						<span class="font-medium text-white">Was ist mit Datenschutz?</span>
						<svg class="w-5 h-5 text-[#666]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
					</button>
					<div class="px-6 pb-4 hidden">
						<p class="text-[#888]">Alle Mandantendaten bleiben vertraulich. Ich optimiere nur öffentlich verfügbare Informationen. Keine Mandantendaten werden verarbeitet.</p>
					</div>
				</div>
				
				<!-- Voice Search Optimized FAQ 2026 -->
				<div class="bg-[#1a1a1a] rounded-xl border border-[#333] overflow-hidden mt-4">
					<button class="w-full px-6 py-4 text-left flex justify-between items-center" onclick="this.nextElementSibling.classList.toggle('hidden')">
						<span class="font-medium text-white">Wie finde ich mehr Mandanten als Anwalt in Basel?</span>
						<svg class="w-5 h-5 text-[#666]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
