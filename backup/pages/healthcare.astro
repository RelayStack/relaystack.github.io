---
import Layout from '../layouts/Layout.astro';
---

<Layout title="SEO für Ärzte Basel: Mehr Patienten durch Google | RelayStack">

	<!-- Navigation -->
	<header class="fixed top-0 left-0 right-0 z-50 bg-[#111111]/95 backdrop-blur-md border-b border-[#222]">
		<div class="max-w-6xl mx-auto px-6 py-4 flex justify-between items-center">
			<a href="/" class="text-xl font-bold tracking-tight">
				<span class="text-white">relay</span><span class="text-orange-600">stack</span>
			</a>
			<nav class="hidden md:flex gap-6 text-sm">
				<a href="/" class="text-[#888] hover:text-white">Startseite</a>
				<a href="#pain" class="text-[#888] hover:text-white">Probleme</a>
				<a href="#loesung" class="text-[#888] hover:text-white">Lösung</a>
				<a href="#rechner" class="text-[#888] hover:text-white">ROI</a>
				<a href="#preise" class="text-[#888] hover:text-white">Preise</a>
			</nav>
			<a href="https://calendly.com/relaystack/15min" class="px-5 py-2.5 bg-green-600 text-white text-sm font-semibold rounded-lg hover:bg-green-700">Gratis Analyse buchen</a>
		</div>
	</header>

	<!-- 2026 Breadcrumb Navigation -->
	<nav aria-label="Breadcrumb" class="pt-20 pb-4 bg-[#111111]">
		<div class="max-w-6xl mx-auto px-6">
			<ol class="flex items-center gap-2 text-sm text-[#666]" itemscope itemtype="https://schema.org/BreadcrumbList">
				<li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
					<a href="/" itemprop="item" class="hover:text-green-500 transition-colors">
						<span itemprop="name">Startseite</span>
					</a>
					<meta itemprop="position" content="1" />
				</li>
				<li class="text-[#444]">/</li>
				<li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
					<span itemprop="name" class="text-green-500">Gesundheit</span>
					<meta itemprop="position" content="2" />
				</li>
			</ol>
		</div>
	</nav>

	<!-- Hero Section -->
	<section class="min-h-[85vh] flex items-center pt-24 pb-16">
		<div class="max-w-4xl mx-auto px-6 text-center">
			<span class="inline-block px-4 py-2 bg-green-600/20 text-green-500 text-sm font-medium rounded-full mb-6">
			 für Ärzte, Zahnärzte und Kliniken
			</span>
			
			<h1 class="text-4xl md:text-5xl font-bold leading-tight mb-6">
				<span class="text-white">82% der Patienten lesen Bewertungen vor der Wahl.</span><br/>
				<span class="text-green-500">Was sehen sie, wenn sie nach Ihnen suchen?</span>
			</h1>
			
			<p class="text-lg text-[#999] max-w-2xl mx-auto mb-8 leading-relaxed">
				64% der Schweizer Patienten suchen nach Symptomen, bevor sie einen Arzt kontaktieren. Wenn Ihre Praxis nicht bei "Zahnschmerzen Notfall Basel" auf Seite 1 ist, wählen sie einen anderen. Ein Patient bleibt Jahre.
			</p>
			
			<div class="flex flex-col sm:flex-row gap-4 justify-center mb-10">
				<a href="https://calendly.com/relaystack/15min" class="px-8 py-4 bg-green-600 text-white font-semibold rounded-lg hover:bg-green-700 transition-all hover:scale-105 text-lg">
					Kostenlose Analyse buchen
				</a>
				<a href="#loesung" class="px-8 py-4 border-2 border-green-600 text-green-500 font-semibold rounded-lg hover:bg-green-600 hover:text-white transition-all">
					So funktioniert es
				</a>
			</div>
			
			<!-- Trust Stats -->
			<div class="grid grid-cols-3 gap-4 max-w-xl mx-auto">
				<div class="bg-[#1a1a1a] p-4 rounded-lg">
					<p class="text-2xl font-bold text-green-500">15+</p>
					<p class="text-xs text-[#666]">Praxen optimiert</p>
				</div>
				<div class="bg-[#1a1a1a] p-4 rounded-lg">
					<p class="text-2xl font-bold text-green-500">5x</p>
					<p class="text-xs text-[#666]">Mehr Anfragen</p>
				</div>
				<div class="bg-[#1a1a1a] p-4 rounded-lg">
					<p class="text-2xl font-bold text-green-500">120T</p>
					<p class="text-xs text-[#666]">Seite-1 Garantie</p>
				</div>
			</div>
		</div>
	</section>

	<!-- Pain Points Section -->
	<section id="pain" class="py-24 bg-[#151515]">
		<div class="max-w-4xl mx-auto px-6">
			<div class="text-center mb-16">
				<p class="text-sm text-green-600 font-medium mb-2">DAS PROBLEM</p>
				<h2 class="text-4xl font-bold text-white mb-4">Warum Praxen Patienten verlieren</h2>
			</div>
			
			<div class="space-y-6">
				<div class="bg-[#1a1a1a] p-6 rounded-xl border border-[#333]">
					<h3 class="text-lg font-semibold text-white mb-2">1. Patienten googeln Symptome</h3>
					<p class="text-[#888]">64% suchen nach Symptomen, bevor sie einen Arzt rufen. "Zahnschmerzen Notfall", "Hautarzt Muttermal", "Kniechirurg Basel". Wenn Sie nicht für diese Begriffe ranken, existieren Sie nicht.</p>
				</div>
				
				<div class="bg-[#1a1a1a] p-6 rounded-xl border border-[#333]">
					<h3 class="text-lg font-semibold text-white mb-2">2. Bewertungen entscheiden</h3>
	003cp class="text-[#888]">82% der Patienten lesen Bewertungen vor der Wahl. Ohne aktives Bewertungsmanagement verlieren Sie an Praxen mit 4.6+ Sternen.</p>
				</div>
				
				<div class="bg-[#1a1a1a] p-6 rounded-xl border border-[#333]">
					<h3 class="text-lg font-semibold text-white mb-2">3. Keine Online-Terminbuchung</h3>
					<p class="text-[#888]">Patienten erwarten Online-Buchung. Wenn sie anrufen müssen und niemand rangeht, buchen sie bei der Praxis mit Online-Formular.</p>
				</div>
				
				<div class="bg-[#1a1a1a] p-6 rounded-xl border border-[#333]">
					<h3 class="text-lg font-semibold text-white mb-2">4. Fehlende Versicherungs-Info</h3>
					<p class="text-[#888]">Keine Information über Kassen oder Privatpatienten = 25% mehr Ausfälle. Patienten wissen nicht, ob Sie ihre Kasse akzeptieren.</p>
				</div>
				
				<div class="bg-[#1a1a1a] p-6 rounded-xl border border-[#333]">
					<h3 class="text-lg font-semibold text-white mb-2">5. YMYL-Penalties für dünne Inhalte</h3>
					<p class="text-[#888]">Google bestraft medizinische Websites ohne Credentials. Ohne E-E-A-T Signale (Expertise, Autorität, Vertrauen) ranken Sie nicht.</p>
				</div>
			</div>
		</div>
	</section>

	<!-- Cost of Inaction -->
	<section class="py-16 bg-[#111]">
		<div class="max-w-3xl mx-auto px-6">
			<div class="bg-[#1a1a1a] p-8 rounded-xl border border-[#333]">
				<h3 class="text-xl font-bold text-white mb-6 text-center">Was kostet eine leere Wartezimmer?</h3>
				<div class="grid md:grid-cols-2 gap-6">
					<div>
						<label class="block text-sm text-[#888] mb-2">Patientenumatz (CHF)</label>
						<input type="number" id="avgPatient" value="250" class="w-full px-4 py-3 bg-[#222] border border-[#444] rounded-lg text-white" onchange="calculateCostHealth()" />
					</div>
					<div>
						<label class="block text-sm text-[#888] mb-2">Verlorene Patienten/Monat</label>
						<input type="number" id="lostPatients" value="10" class="w-full px-4 py-3 bg-[#222] border border-[#444] rounded-lg text-white" onchange="calculateCostHealth()" />
					</div>
				</div>
				<div class="mt-6 p-4 bg-red-900/20 rounded-lg border border-red-500/30">
					<p class="text-red-400 font-semibold">Sie verlieren monatlich: <span id="monthlyCostHealth" class="text-2xl">CHF 2'500</span></p>
					<p class="text-sm text-[#666] mt-2">Ein Patient bleibt Jahre. Der Lifetime Value ist CHF 3'000+. Jeder verlorene Patient ist ein Vermoegen.</p>
				</div>
			</div>
			
			<script>
				function calculateCostHealth() {
					const avgPatient = parseFloat(document.getElementById('avgPatient').value) || 250;
					const lostPatients = parseFloat(document.getElementById('lostPatients').value) || 10;
					
					const monthly = avgPatient * lostPatients;
					document.getElementById('monthlyCostHealth').textContent = 'CHF ' + monthly.toLocaleString();
				}
			</script>
		</div>
	</section>

	<!-- Solution Process -->
	<section id="loesung" class="py-24">
		<div class="max-w-5xl mx-auto px-6">
			<div class="text-center mb-16">
				<p class="text-sm text-green-600 font-medium mb-2">MEINE METHODE</p>
				<h2 class="text-4xl font-bold text-white mb-4">4 Schritte zu mehr Patienten</h2>
			</div>
			
			<div class="space-y-8">
				<!-- Step 1 -->
				<div class="flex flex-col md:flex-row gap-8 items-start">
					<div class="w-16 h-16 bg-green-600 rounded-2xl flex items-center justify-center shrink-0">
						<span class="text-white text-2xl font-bold">1</span>
					</div>
					<div class="flex-1">
						<h3 class="text-xl font-bold text-white mb-3">Analyse und Strategie</h3>
						<p class="text-[#888] mb-4">Ich analysiere Ihre Praxis und Konkurrenz. Sie erhalten einen Bericht mit:</p>
						<ul class="space-y-2 text-[#ccc]">
							<li class="flex items-start gap-2"><span class="text-green-500">✓</span> SEO-Score Ihrer Praxis-Website</li>
							<li class="flex items-start gap-2"><span class="text-green-500">✓</span> Symptom-Keyword-Potenziale</li>
							<li class="flex items-start gap-2"><span class="text-green-500">✓</span> Konkurrenz-Analyse</li>
							<li class="flex items-start gap-2"><span class="text-green-500">✓</span> E-E-A-T Empfehlungen</li>
						</ul>
					</div>
				</div>
				
				<!-- Step 2 -->
				<div class="flex flex-col md:flex-row gap-8 items-start">
					<div class="w-16 h-16 bg-green-600 rounded-2xl flex items-center justify-center shrink-0">
						<span class="text-white text-2xl font-bold">2</span>
					</div>
					<div class="flex-1">
						<h3 class="text-xl font-bold text-white mb-3">Google Business und Zulassungen</h3>
						<p class="text-[#888] mb-4">Ihr Profil zeigt Professionalitaet:</p>
						<ul class="space-y-2 text-[#ccc]">
							<li class="flex items-start gap-2"><span class="text-green-500">✓</span> Vollständiges Profil mit FMH-Zulassung</li>
							<li class="flex items-start gap-2"><span class="text-green-500">✓</span> Facharzt-Status hervorgehoben</li>
							<li class="flex items-start gap-2"><span class="text-green-500">✓</span> Bewertungsmanagement</li>
							<li class="flex items-start gap-2"><span class="text-green-500">✓</span> Sprechzeiten und Terminbuchung</li>
						</ul>
					</div>
				</div>
				
				<!-- Step 3 -->
				<div class="flex flex-col md:flex-row gap-8 items-start">
					<div class="w-16 h-16 bg-green-600 rounded-2xl flex items-center justify-center shrink-0">
						<span class="text-white text-2xl font-bold">3</span>
					</div>
					<div class="flex-1">
						<h3 class="text-xl font-bold text-white mb-3">Website für Patienten</h3>
						<p class="text-[#888] mb-4">Ihre Website wird für medizinische Keywords optimiert:</p>
						<ul class="space-y-2 text-[#ccc]">
							<li class="flex items-start gap-2"><span class="text-green-500">✓</span> Symptom-basierte Seiten</li>
							<li class="flex items-start gap-2"><span class="text-green-500">✓</span> Online-Terminbuchung</li>
							<li class="flex items-start gap-2"><span class="text-green-500">✓</span> Kassen-Information</li>
							<li class="flex items-start gap-2"><span class="text-green-500">✓</span> Mobile-First Design</li>
						</ul>
					</div>
				</div>
				
				<!-- Step 4 -->
				<div class="flex flex-col md:flex-row gap-8 items-start">
					<div class="w-16 h-16 bg-green-600 rounded-2xl flex items-center justify-center shrink-0">
						<span class="text-white text-2xl font-bold">4</span>
					</div>
					<div class="flex-1">
						<h3 class="text-xl font-bold text-white mb-3">Content und Compliance</h3>
						<p class="text-[#888] mb-4">Nach FMH-Richtlinien:</p>
						<ul class="space-y-2 text-[#ccc]">
							<li class="flex items-start gap-2"><span class="text-green-500">✓</span> Medizinische Ratgeber</li>
							<li class="flex items-start gap-2"><span class="text-green-500">✓</span> FAQ für Patienten</li>
							<li class="flex items-start gap-2"><span class="text-green-500">✓</span> Mehrsprachige Inhalte</li>
							<li class="flex items-start gap-2"><span class="text-green-500">✓</span> 3 Monate Support</li>
						</ul>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- ROI Calculator -->
	<section id="rechner" class="py-24 bg-[#151515]">
		<div class="max-w-3xl mx-auto px-6">
			<div class="text-center mb-12">
				<p class="text-sm text-green-600 font-medium mb-2">ROI RECHNER</p>
				<h2 class="text-4xl font-bold text-white">Ein Patient bleibt Jahre</h2>
			</div>
			
			<div class="bg-[#1a1a1a] p-8 rounded-xl border border-[#333]">
				<div class="grid md:grid-cols-2 gap-8 mb-8">
					<div>
						<label class="block text-sm text-[#888] mb-2">Patientenumatz (CHF)</label>
						<input type="number" id="avgPatientHealth" value="250" class="w-full px-4 py-3 bg-[#222] border border-[#444] rounded-lg text-white" onchange="calculateROIHealth()" />
					</div>
					<div>
						<label class="block text-sm text-[#888] mb-2">Neue Patienten/Monat</label>
						<input type="number" id="newPatients" value="10" class="w-full px-4 py-3 bg-[#222] border border-[#444] rounded-lg text-white" onchange="calculateROIHealth()" />
					</div>
				</div>
				
				<div class="border-t border-[#333] pt-6">
					<div class="flex justify-between items-center mb-2">
						<span class="text-[#888]">Zusätzlicher Umsatz pro Monat:</span>
						<span id="monthlyRevenueHealth" class="text-2xl font-bold text-green-500">CHF 2'500</span>
					</div>
					<div class="flex justify-between items-center mb-2">
						<span class="text-[#888]">Zusätzlicher Umsatz pro Jahr:</span>
						<span id="yearlyRevenueHealth" class="text-2xl font-bold text-green-500">CHF 30'000</span>
					</div>
					<div class="flex justify-between items-center">
						<span class="text-[#888]">Ihre Investition:</span>
						<span class="text-xl font-bold text-green-500">CHF 3'900 einmalig</span>
					</div>
				</div>
				
				<div class="mt-6 p-4 bg-green-600/20 rounded-lg border border-green-600/30">
					<p class="text-green-400 font-semibold">ROI: <span id="roiValueHealth">669%</span> im ersten Jahr</p>
				</div>
			</div>
			
			<script>
				function calculateROIHealth() {
					const avgPatient = parseFloat(document.getElementById('avgPatientHealth').value) || 250;
					const newPatients = parseFloat(document.getElementById('newPatients').value) || 10;
					const investment = 3900;
					
					const monthly = avgPatient * newPatients;
					const yearly = monthly * 12;
					const roi = Math.round(((yearly - investment) / investment) * 100);
					
					document.getElementById('monthlyRevenueHealth').textContent = 'CHF ' + monthly.toLocaleString();
					document.getElementById('yearlyRevenueHealth').textContent = 'CHF ' + yearly.toLocaleString();
					document.getElementById('roiValueHealth').textContent = roi + '%';
				}
			</script>
		</div>
	</section>

	<!-- Pricing -->
	<section id="preise" class="py-24">
		<div class="max-w-4xl mx-auto px-6">
			<div class="text-center mb-12">
				<p class="text-sm text-green-600 font-medium mb-2">PREISE</p>
				<h2 class="text-4xl font-bold text-white">Transparente Investition</h2>
			</div>
			
			<div class="grid md:grid-cols-2 gap-6">
				<div class="bg-[#1a1a1a] p-8 rounded-xl border border-[#333]">
					<div class="inline-block px-3 py-1 bg-blue-600/20 text-blue-400 text-xs font-medium rounded-full mb-4">Für bestehende Praxen</div>
					<h3 class="text-lg font-semibold text-white">Praxis SEO Boost</h3>
					<div class="mt-4 mb-2">
						<span class="text-3xl font-bold text-white">CHF 990</span>
					</div>
					<p class="text-xs text-[#555]">Einmalig, 2 Wochen Support</p>
					<ul class="mt-6 space-y-2 text-sm text-[#888]">
						<li>✓ Google Business Profil Optimierung</li>
						<li>✓ E-E-A-T Optimierung</li>
						<li>✓ Technisches SEO-Audit</li>
						<li>✓ Schema-Markup für Praxen</li>
						<li>✓ Bewertungsmanagement</li>
					</ul>
					<a href="https://calendly.com/relaystack/15min" class="block mt-6 w-full px-4 py-3 border border-[#444] text-[#ccc] text-center text-sm font-semibold rounded-lg hover:border-green-600 hover:text-green-500 transition-all">Beratung buchen</a>
				</div>
				
				<div class="bg-[#111] p-8 rounded-xl border-2 border-green-600 relative">
					<span class="absolute -top-3 left-1/2 -translate-x-1/2 px-4 py-1 bg-green-600 text-white text-xs font-bold rounded-full">BELIEBTESTE</span>
					<div class="inline-block px-3 py-1 bg-green-600/20 text-green-400 text-xs font-medium rounded-full mb-4">Komplettlösung</div>
					<h3 class="text-lg font-semibold text-white">Praxis Pro</h3>
					<div class="mt-4 mb-2">
						<span class="text-3xl font-bold text-white">CHF 3'900</span>
					</div>
					<p class="text-xs text-green-500">oder CHF 390/Monat x 10</p>
					<ul class="mt-6 space-y-2 text-sm text-[#ccc]">
						<li>✓ Alles aus Praxis SEO Boost</li>
						<li>✓ Professionelle Website (5-7 Seiten)</li>
						<li>✓ Online-Terminbuchung</li>
						<li>✓ Symptom-basierte Seiten</li>
						<li>✓ 120-Tage Seite-1-Garantie</li>
					</ul>
					<a href="https://calendly.com/relaystack/15min" class="block mt-6 w-full px-4 py-3 bg-green-600 text-white text-center text-sm font-bold rounded-lg hover:bg-green-700 transition-all">Jetzt buchen</a>
				</div>
			</div>
		</div>
	</section>

	<!-- FAQ -->
	<section class="py-24 bg-[#151515]">
		<div class="max-w-3xl mx-auto px-6">
			<div class="text-center mb-12">
				<p class="text-sm text-green-600 font-medium mb-2">FAQ</p>
				<h2 class="text-3xl font-bold text-white">Häufige Fragen</h2>
			</div>
			
			<div class="space-y-4">
				<div class="bg-[#1a1a1a] rounded-xl border border-[#333] overflow-hidden">
					<button class="w-full px-6 py-4 text-left flex justify-between items-center" onclick="this.nextElementSibling.classList.toggle('hidden')">
						<span class="font-medium text-white">Ist SEO für Ärzte ethisch?</span>
						<svg class="w-5 h-5 text-[#666]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
					</button>
					<div class="px-6 pb-4 hidden">
						<p class="text-[#888]">Absolut. Ich arbeite nach FMH-Richtlinien. Faktische Informationen, keine Werbeversprechen. Alle Inhalte werden von Ihnen freigegeben.</p>
					</div>
				</div>
				
				<div class="bg-[#1a1a1a] rounded-xl border border-[#333] overflow-hidden">
					<button class="w-full px-6 py-4 text-left flex justify-between items-center" onclick="this.nextElementSibling.classList.toggle('hidden')">
						<span class="font-medium text-white">Wie lange dauert es?</span>
						<svg class="w-5 h-5 text-[#666]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
					</button>
					<div class="px-6 pb-4 hidden">
						<p class="text-[#888]">Erste Ergebnisse nach 4-8 Wochen. Ich garantiere Seite-1-Platzierung für Ihre Top-Keywords innerhalb von 120 Tagen.</p>
					</div>
				</div>
				
				<!-- Voice Search Optimized FAQ 2026 -->
				<div class="bg-[#1a1a1a] rounded-xl border border-[#333] overflow-hidden mt-4">
					<button class="w-full px-6 py-4 text-left flex justify-between items-center" onclick="this.nextElementSibling.classList.toggle('hidden')">
						<span class="font-medium text-white">Wie bekomme ich mehr Patienten für meine Praxis?</span>
						<svg class="w-5 h-5 text-[#666]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
					</button>
					<div class="px-6 pb-4 hidden">
						<p class="text-[#888]">Um mehr Patienten zu bekommen, optimieren Sie Ihre Praxis-Website für Symptom-Keywords wie "Zahnschmerzen Notfall Basel" oder "Hautarzt Muttermal". 64% der Patienten suchen nach Symptomen, bevor sie einen Arzt rufen. Ein vollständiges Google Business Profil mit FMH-Zulassung, aktive Bewertungsmanagement und Online-Terminbuchung sind ebenfalls entscheidend. 82% lesen Bewertungen vor der Arztwahl.</p>
					</div>
				</div>
				
				<div class="bg-[#1a1a1a] rounded-xl border border-[#333] overflow-hidden mt-4">
					<button class="w-full px-6 py-4 text-left flex justify-between items-center" onclick="this.nextElementSibling.classList.toggle('hidden')">
						<span class="font-medium text-white">Was kostet SEO für Ärzte und Praxen?</span>
						<svg class="w-5 h-5 text-[#666]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
