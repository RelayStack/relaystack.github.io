---
interface Props {
	title: string;
	description?: string;
	image?: string;
}

const { title, description = "Freelance SEO specialist & web developer in Basel, Switzerland. I help businesses rank on Google page 1 with high-converting websites. 10+ years exp, 120-day guarantee.", image = "/og-image.svg" } = Astro.props;

const canonicalURL = Astro.url.href;
const siteName = "RelayStack - SEO Specialist & Web Developer";
