			let currentLang = localStorage.getItem('lang') || 'en';
			
			function updateContent() {
				const t = translations[currentLang];
				
				// Update text content
				document.querySelectorAll('[data-i18n]').forEach(el => {
					const key = el.getAttribute('data-i18n');
					const keys = key.split('.');
					let val = t;
					for (const k of keys) {
						val = val?.[k];
					}
					if (val && typeof val === 'string') {
						el.textContent = val;
					}
				});
				
				// Update placeholders
				document.querySelectorAll('[data-i18n-placeholder]').forEach(el => {
					const key = el.getAttribute('data-i18n-placeholder');
					const keys = key.split('.');
					let val = t;
					for (const k of keys) {
						val = val?.[k];
					}
					if (val && typeof val === 'string') el.placeholder = val;
				});
				
				// Update step labels if form exists
				const stepLabel = document.getElementById('stepLabel');
				if (stepLabel && t.form) {
					const currentStep = parseInt(document.getElementById('currentStepNum')?.textContent || '1');
					const labels = [t.form.step1Label, t.form.step2Label, t.form.step3Label, t.form.step4Label];
					stepLabel.textContent = labels[currentStep - 1] || '';
				}
			}
			
			function setLang(lang) {
				currentLang = lang;
				localStorage.setItem('lang', lang);
				updateContent();
				document.documentElement.lang = lang;
				document.querySelectorAll('.lang-btn').forEach(btn => {
					btn.classList.toggle('bg-orange-600', btn.dataset.lang === lang);
					btn.classList.toggle('bg-[#222]', btn.dataset.lang !== lang);
				});
			}
			
			document.addEventListener('DOMContentLoaded', () => {
				setLang(currentLang);
			});
			
			window.setLang = setLang;
		</script>
	</body>
