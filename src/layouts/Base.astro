---
import '../styles/fonts.css';
import '../styles/global.css';
import Meta from '../components/layout/Meta.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  noHeader?: boolean;
  noFooter?: boolean;
  breadcrumbs?: { name: string; url: string }[];
}

const { 
  title,
  description,
  image,
  noHeader = false,
  noFooter = false,
  breadcrumbs
} = Astro.props;

const lang = Astro.currentLocale || 'en';
const siteUrl = 'https://buweb.ch';

const breadcrumbJson = breadcrumbs && breadcrumbs.length > 0 ? JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": breadcrumbs.map((crumb, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": crumb.name,
    "item": new URL(crumb.url, siteUrl).href
  }))
}) : null;
---

<!doctype html>
<html lang={lang} class="dark">
  <head>
    <Meta title={title} description={description} image={image} />
    {breadcrumbJson && (
      <script type="application/ld+json" set:html={breadcrumbJson} />
    )}
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js" defer></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js" defer></script>
  </head>
  <body class="min-h-screen bg-bg-primary text-text-primary antialiased">
    <!-- Noise Overlay -->
    <div class="noise-overlay" aria-hidden="true"></div>
    
    <!-- Custom Cursor -->
    <div class="custom-cursor" id="cursor" aria-hidden="true"></div>
    
    {!noHeader && <Header />}
    <main>
      <slot />
    </main>
    {!noFooter && <Footer />}
    
    <!-- Floating Action Buttons -->
    <div class="fixed bottom-6 right-6 z-50 flex flex-col gap-3 items-end">
      <!-- WhatsApp -->
      <a 
        href="https://wa.me/41764218425?text=Hi%20buweb.ch,%20I%20am%20interested%20in%20SEO%20services"
        target="_blank"
        rel="noopener noreferrer"
        class="w-14 h-14 bg-green-500 rounded-full flex items-center justify-center shadow-lg shadow-green-500/30 hover:scale-110 transition-transform"
        aria-label="WhatsApp"
      >
        <svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 24 24">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
      </a>
      
      <!-- Call button (mobile only) -->
      <a 
        href="tel:+41764218425"
        class="md:hidden w-14 h-14 bg-accent rounded-full flex items-center justify-center shadow-lg shadow-accent/30 hover:scale-110 transition-transform"
        aria-label="Call"
      >
        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
        </svg>
      </a>
    </div>
    
    <!-- Exit Intent Popup -->
    <div id="exitPopup" class="fixed inset-0 z-[99] hidden items-center justify-center p-4">
      <div class="absolute inset-0 bg-black/80 backdrop-blur-sm" onclick="closeExitPopup()"></div>
      <div class="relative glass-strong rounded-3xl p-8 md:p-12 max-w-lg w-full text-center">
        <button onclick="closeExitPopup()" class="absolute top-4 right-4 w-8 h-8 bg-white/5 rounded-full flex items-center justify-center text-text-muted hover:text-text-primary">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
        <h3 class="text-2xl md:text-3xl font-display font-normal mb-4">{lang === 'de' ? 'Warten Sie — bevor Sie gehen!' : 'Wait — before you go!'}</h3>
        <p class="text-text-secondary mb-6">{lang === 'de' ? 'Holen Sie sich Ihr kostenloses SEO-Audit. In 24 Stunden wissen Sie genau, was Ihre Website von Seite 1 zurückhält.' : 'Get your free SEO audit. In 24 hours you will know exactly what is holding your website back from page 1.'}</p>
        <button 
          onclick="closeExitPopup(); document.dispatchEvent(new CustomEvent('openLeadForm'));"
          class="w-full px-6 py-4 bg-accent text-white font-medium rounded-xl hover:bg-accent-hover transition-colors"
        >
          {lang === 'de' ? 'Gratis Audit anfordern' : 'Get Free Audit'}
        </button>
        <p class="text-text-muted text-xs mt-4">{lang === 'de' ? 'Kein Spam. Keine Kreditkarte.' : 'No spam. No credit card.'}</p>
      </div>
    </div>
    
    <script>
      function initBuweb() {
        // Initialize GSAP ScrollTrigger
        if (typeof gsap !== 'undefined' && typeof ScrollTrigger !== 'undefined') {
          gsap.registerPlugin(ScrollTrigger);
          
          document.querySelectorAll('.reveal').forEach(el => {
            ScrollTrigger.create({
              trigger: el,
              start: 'top 85%',
              onEnter: () => el.classList.add('active'),
              once: true
            });
          });
          
          document.querySelectorAll('.stagger-children').forEach(container => {
            ScrollTrigger.create({
              trigger: container,
              start: 'top 80%',
              onEnter: () => container.classList.add('active'),
              once: true
            });
          });
          
          document.querySelectorAll('.text-reveal').forEach(el => {
            ScrollTrigger.create({
              trigger: el,
              start: 'top 85%',
              onEnter: () => el.classList.add('active'),
              once: true
            });
          });
          
          gsap.utils.toArray('.parallax').forEach(el => {
            const speed = el.dataset.speed || 0.5;
            gsap.to(el, {
              y: () => speed * 100,
              ease: 'none',
              scrollTrigger: {
                trigger: el,
                start: 'top bottom',
                end: 'bottom top',
                scrub: true
              }
            });
          });
        }
        
        // Custom cursor (desktop only)
        const cursor = document.getElementById('cursor');
        if (cursor && window.matchMedia('(pointer: fine)').matches) {
          let mouseX = 0, mouseY = 0;
          let cursorX = 0, cursorY = 0;
          let rafId = null;
          
          document.addEventListener('mousemove', (e) => {
            mouseX = e.clientX;
            mouseY = e.clientY;
          });
          
          function animateCursor() {
            cursorX += (mouseX - cursorX) * 0.15;
            cursorY += (mouseY - cursorY) * 0.15;
            cursor.style.left = cursorX + 'px';
            cursor.style.top = cursorY + 'px';
            rafId = requestAnimationFrame(animateCursor);
          }
          animateCursor();
          
          const interactiveElements = document.querySelectorAll('a, button, [onclick], input, select, textarea, .magnetic');
          interactiveElements.forEach(el => {
            el.addEventListener('mouseenter', () => cursor.classList.add('hover'));
            el.addEventListener('mouseleave', () => cursor.classList.remove('hover'));
          });
          
          document.addEventListener('visibilitychange', () => {
            if (document.hidden && rafId) {
              cancelAnimationFrame(rafId);
            } else if (!document.hidden && window.matchMedia('(pointer: fine)').matches) {
              animateCursor();
            }
          });
        } else if (cursor) {
          cursor.style.display = 'none';
        }
        
        // Magnetic button effect
        document.querySelectorAll('.magnetic').forEach(el => {
          el.addEventListener('mousemove', (e) => {
            const rect = el.getBoundingClientRect();
            const x = e.clientX - rect.left - rect.width / 2;
            const y = e.clientY - rect.top - rect.height / 2;
            el.style.transform = `translate(${x * 0.3}px, ${y * 0.3}px)`;
          });
          
          el.addEventListener('mouseleave', () => {
            el.style.transform = 'translate(0, 0)';
          });
        });
        
        // Header hide on scroll
        const header = document.querySelector('header');
        let lastScroll = 0;
        let ticking = false;
        
        window.addEventListener('scroll', () => {
          if (!ticking) {
            requestAnimationFrame(() => {
              const currentScroll = window.scrollY;
              if (header) {
                if (currentScroll > lastScroll && currentScroll > 100) {
                  header.style.transform = 'translateY(-100%)';
                } else {
                  header.style.transform = 'translateY(0)';
                }
                header.style.background = currentScroll > 50 
                  ? 'rgba(10, 10, 10, 0.8)' 
                  : 'transparent';
              }
              lastScroll = currentScroll;
              ticking = false;
            });
            ticking = true;
          }
        }, { passive: true });
        
        // Exit intent
        let exitShown = false;
        function showExitPopup() {
          if (exitShown) return;
          const popup = document.getElementById('exitPopup');
          if (popup) {
            popup.classList.remove('hidden');
            popup.classList.add('flex');
            exitShown = true;
          }
        }
        window.closeExitPopup = function() {
          const popup = document.getElementById('exitPopup');
          if (popup) {
            popup.classList.add('hidden');
            popup.classList.remove('flex');
          }
        };
        document.addEventListener('mouseout', (e) => {
          if (e.clientY < 10 && !exitShown) {
            showExitPopup();
          }
        });
        
        // Show exit popup on back button (mobile)
        let backPressCount = 0;
        window.addEventListener('popstate', () => {
          backPressCount++;
          if (backPressCount === 1 && !exitShown) {
            showExitPopup();
            history.pushState(null, '', location.href);
          }
        });
        history.pushState(null, '', location.href);
      }
      
      if (document.readyState === 'complete' || document.readyState === 'interactive') {
        initBuweb();
      } else {
        document.addEventListener('DOMContentLoaded', initBuweb);
      }
    </script>
  </body>
</html>
