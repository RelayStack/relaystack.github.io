---
interface Props {
  type?: 'text' | 'email' | 'tel' | 'url' | 'number';
  name: string;
  id: string;
  placeholder?: string;
  required?: boolean;
  value?: string;
  class?: string;
}

const {
  type = 'text',
  name,
  id,
  placeholder,
  required = false,
  value,
  class: className = ''
} = Astro.props;

const baseStyles = 'w-full px-4 py-3 bg-bg-card border border-border rounded-lg text-text-primary placeholder-text-muted focus:border-accent focus:outline-none transition-colors';
---

<input
  type={type}
  name={name}
  id={id}
  placeholder={placeholder}
  required={required}
  value={value}
  class={`${baseStyles} ${className}`}
/>