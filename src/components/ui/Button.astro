---
interface Props {
  variant?: 'primary' | 'secondary' | 'outline' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  type?: 'button' | 'submit' | 'reset';
  href?: string;
  onclick?: string;
  class?: string;
  magnetic?: boolean;
}

const { 
  variant = 'primary',
  size = 'md',
  type = 'button',
  href,
  onclick,
  class: className = '',
  magnetic = true
} = Astro.props;

const baseStyles = 'inline-flex items-center justify-center gap-2 font-medium transition-all duration-300 rounded-full focus:outline-none';

const variants = {
  primary: 'bg-accent text-white hover:bg-accent-hover hover:shadow-lg hover:shadow-accent/30 active:scale-95',
  secondary: 'bg-white/5 text-text-primary hover:bg-white/10 border border-white/10 hover:border-white/20',
  outline: 'bg-transparent text-accent border border-accent hover:bg-accent hover:text-white',
  ghost: 'bg-transparent text-text-secondary hover:text-text-primary'
};

const sizes = {
  sm: 'px-5 py-2.5 text-sm',
  md: 'px-7 py-3.5 text-base',
  lg: 'px-10 py-4 text-lg'
};

const magneticClass = magnetic ? 'magnetic' : '';
const classes = `${baseStyles} ${variants[variant]} ${sizes[size]} ${magneticClass} ${className}`;
---

{href ? (
  <a href={href} class={classes} onclick={onclick}>
    <slot />
  </a>
) : (
  <button type={type} class={classes} onclick={onclick}>
    <slot />
  </button>
)}
