---
import Button from '../ui/Button.astro';

const lang = Astro.currentLocale || 'en';
const t = await import(`../../i18n/${lang}.json`).then(m => m.default);
---

<section class="relative py-40 overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-b from-bg-primary via-bg-secondary to-bg-primary"></div>
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_50%,rgba(255,77,0,0.15)_0%,transparent_70%)]"></div>

  <div class="container-custom relative z-10">
    <div class="reveal max-w-4xl mx-auto text-center">
      <p class="text-accent text-sm font-medium tracking-wider uppercase mb-6">{lang === 'de' ? 'Kostenlos Starten' : 'Start for Free'}</p>
      <h2 class="text-5xl md:text-6xl lg:text-8xl font-display font-normal mb-8 leading-tight">
        {t.finalCta.headline}
      </h2>
      <p class="text-text-secondary text-xl max-w-2xl mx-auto mb-12 leading-relaxed">
        {t.finalCta.subheadline}
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center mb-16">
        <Button 
          variant="primary" 
          size="lg"
          onclick="document.dispatchEvent(new CustomEvent('openLeadForm'))"
          class="min-w-[280px]"
        >
          {t.hero.ctaPrimary}
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </Button>
        <Button 
          variant="secondary" 
          size="lg"
          href="tel:+41764218425"
          class="min-w-[280px]"
          magnetic={false}
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          {t.hero.ctaSecondary}
        </Button>
      </div>

      {/* Trust badges */}
      <div class="flex flex-wrap items-center justify-center gap-8 text-text-muted text-sm">
        <span class="flex items-center gap-2">
          <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
          </svg>
          {lang === 'de' ? 'Kein Kreditkarte' : 'No credit card'}
        </span>
        <span class="flex items-center gap-2">
          <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          {lang === 'de' ? 'Antwort in 24h' : 'Reply within 24h'}
        </span>
        <span class="flex items-center gap-2">
          <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
          </svg>
          {lang === 'de' ? '120 Tage Garantie' : '120-day guarantee'}
        </span>
      </div>
    </div>
  </div>
</section>
