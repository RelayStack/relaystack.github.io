---
import Button from '../ui/Button.astro';
import Card from '../ui/Card.astro';

const lang = Astro.currentLocale || 'en';
const t = await import(`../../i18n/${lang}.json`).then(m => m.default);

const roiExample = {
  investment: 4900,
  result: 210000,
  roi: 4184
};
---

<section class="relative py-40 overflow-hidden" id="pricing">
  <div class="absolute inset-0 bg-gradient-to-b from-bg-primary via-bg-secondary to-bg-primary"></div>
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[1000px] h-[1000px] bg-accent/5 rounded-full blur-[300px]"></div>

  <div class="container-custom relative z-10">
    <div class="text-center mb-20">
      <p class="reveal text-accent text-sm font-medium tracking-wider uppercase mb-4">{t.pricing.label}</p>
      <h2 class="reveal reveal-delay-1 text-4xl md:text-5xl lg:text-6xl font-display font-normal mb-6">{t.pricing.headline}</h2>
      <p class="reveal reveal-delay-2 text-text-secondary text-lg max-w-2xl mx-auto">
        {t.pricing.subheadline}
      </p>
    </div>

    {/* ROI Preview */}
    <div class="reveal max-w-3xl mx-auto mb-20">
      <Card glass class="p-10 border-gradient">
        <div class="text-center">
          <p class="text-text-secondary mb-6 text-sm uppercase tracking-wider">{lang === 'de' ? 'Beispiel-ROI im ersten Jahr' : 'Sample ROI in Year 1'}</p>
          <div class="flex items-center justify-center gap-8 flex-wrap">
            <div class="text-center">
              <p class="text-4xl font-display">CHF {roiExample.investment.toLocaleString()}</p>
              <p class="text-text-muted text-sm mt-1">{lang === 'de' ? 'Investition' : 'Investment'}</p>
            </div>
            <div class="w-px h-16 bg-white/10 hidden sm:block"></div>
            <div class="text-center">
              <svg class="w-8 h-8 text-accent mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </div>
            <div class="text-center">
              <p class="text-4xl font-display gradient-text">CHF {roiExample.result.toLocaleString()}</p>
              <p class="text-text-muted text-sm mt-1">{lang === 'de' ? 'Rendite' : 'Return'}</p>
            </div>
          </div>
          <div class="mt-6 inline-flex items-center gap-2 px-5 py-2.5 bg-teal/10 text-teal rounded-full text-sm font-medium border border-teal/20">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
            </svg>
            {roiExample.roi}% ROI
          </div>
        </div>
      </Card>
    </div>

    {/* Pricing Cards */}
    <div class="grid md:grid-cols-3 gap-6 max-w-6xl mx-auto items-stretch">
      {t.pricing.tiers.map((tier: any) => (
        <div class="reveal">
          <Card 
            glass={!tier.highlight}
            class={`p-10 flex flex-col h-full relative ${tier.highlight ? 'border-accent ring-1 ring-accent/20 bg-gradient-to-b from-accent/10 to-bg-card/50' : ''}`}
          >
            {tier.highlight && (
              <div class="absolute -top-4 left-1/2 -translate-x-1/2">
                <span class="px-5 py-2 bg-accent text-white text-xs font-bold rounded-full uppercase tracking-wider">{tier.badge}</span>
              </div>
            )}
            
            {!tier.highlight && tier.badge && (
              <span class="inline-block px-4 py-1.5 bg-white/5 text-text-secondary text-xs rounded-full mb-6 w-fit">{tier.badge}</span>
            )}

            <div class="mb-8">
              <h3 class="text-2xl font-display font-normal mb-3">{tier.name}</h3>
              <div class="flex items-baseline gap-2">
                <span class="text-5xl font-display">{tier.price}</span>
              </div>
              {tier.note && <p class="text-teal text-sm mt-2">{tier.note}</p>}
            </div>

            <ul class="space-y-4 mb-10 flex-1">
              {tier.features.map((feature: string) => (
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-accent shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                  </svg>
                  <span class={tier.highlight ? 'text-text-primary' : 'text-text-secondary'}>{feature}</span>
                </li>
              ))}
            </ul>

            <Button 
              variant={tier.highlight ? 'primary' : 'secondary'}
              class="w-full"
              onclick="document.dispatchEvent(new CustomEvent('openLeadForm'))"
            >
              {tier.cta}
            </Button>
          </Card>
        </div>
      ))}
    </div>

    {/* Add-ons */}
    {t.pricing.addons && (
      <div class="reveal max-w-3xl mx-auto mt-16">
        <div class="glass rounded-2xl p-8 text-center">
          <p class="text-text-secondary text-sm uppercase tracking-wider mb-4">{t.pricing.addons.label}</p>
          <div class="flex flex-wrap justify-center gap-3">
            {t.pricing.addons.items.map((item: string) => (
              <span class="px-4 py-2 bg-white/5 text-text-secondary text-sm rounded-full border border-white/10">{item}</span>
            ))}
          </div>
        </div>
      </div>
    )}

    {/* Retainer note */}
    {t.pricing.retainer && (
      <div class="reveal text-center mt-16">
        <p class="text-text-secondary mb-4">{t.pricing.retainer.text}</p>
        <Button variant="outline" onclick="document.dispatchEvent(new CustomEvent('openLeadForm'))">
          {t.pricing.retainer.cta}
        </Button>
      </div>
    )}

    {/* Guarantee */}
    <div class="reveal max-w-2xl mx-auto mt-20">
      <div class="glass-strong rounded-3xl p-12 text-center relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-r from-accent/20 via-transparent to-accent/20"></div>
        <div class="relative z-10">
          <div class="w-20 h-20 bg-accent/10 rounded-full flex items-center justify-center mx-auto mb-6">
            <svg class="w-10 h-10 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
            </svg>
          </div>
          <h3 class="text-3xl font-display font-normal mb-4">
            {lang === 'de' ? '120-Tage Seite-1-Garantie' : '120-Day Page 1 Guarantee'}
          </h3>
          <p class="text-text-secondary">
            {t.guarantee?.text || (lang === 'de' ? 'Wenn Ihre Website nicht innerhalb von 120 Tagen auf Seite 1 kommt, erstatte ich 100% Ihrer Investition. Ohne Wenn und Aber.' : 'If your website doesn\'t reach page 1 within 120 days, I\'ll refund 100% of your investment. No questions asked.')}
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
