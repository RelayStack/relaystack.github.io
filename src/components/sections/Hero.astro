---
import Button from '../ui/Button.astro';

const lang = Astro.currentLocale || 'en';
const t = await import(`../../i18n/${lang}.json`).then(m => m.default);
---

<section class="relative min-h-screen flex items-center overflow-hidden">
  <!-- Rich gradient background -->
  <div class="absolute inset-0 bg-gradient-to-br from-bg-primary via-bg-secondary to-bg-primary"></div>
  <div class="absolute top-0 right-0 w-[70vw] h-[70vh] bg-gradient-radial from-accent/10 via-transparent to-transparent blur-3xl"></div>
  <div class="absolute bottom-0 left-0 w-[50vw] h-[50vh] bg-gradient-radial from-teal/5 via-transparent to-transparent blur-3xl"></div>
  
  <!-- Subtle grid -->
  <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.02)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.02)_1px,transparent_1px)] bg-[size:120px_120px] [mask-image:radial-gradient(ellipse_at_center,black_40%,transparent_80%)]"></div>

  <div class="container-custom relative z-10 py-32">
    <div class="grid lg:grid-cols-12 gap-12 items-center">
      <!-- Left: Main content -->
      <div class="lg:col-span-7">
        <!-- Badge -->
        <div class="reveal reveal-delay-1 inline-flex items-center gap-2 px-4 py-2 bg-accent/10 border border-accent/20 rounded-full mb-8">
          <span class="flex h-1.5 w-1.5 rounded-full bg-accent animate-pulse"></span>
          <span class="text-accent text-sm font-medium tracking-wide">{t.hero.badge}</span>
        </div>

        <!-- Headline with editorial typography -->
        <h1 class="reveal reveal-delay-2 text-5xl md:text-6xl lg:text-7xl xl:text-8xl font-display font-normal tracking-tight mb-8 leading-[1.05]">
          <span class="block text-text-primary">{t.hero.headline}</span>
          <span class="block gradient-text font-editorial mt-2">{t.hero.headlineHighlight}</span>
          <span class="block text-text-primary mt-2">{t.hero.headlineEnd}</span>
        </h1>

        <!-- Subheadline -->
        <p class="reveal reveal-delay-3 text-lg md:text-xl text-text-secondary max-w-xl mb-12 leading-relaxed">
          {t.hero.subheadline}
        </p>

        <!-- CTAs -->
        <div class="reveal reveal-delay-4 flex flex-col sm:flex-row gap-4">
          <Button 
            variant="primary" 
            size="lg"
            onclick="document.dispatchEvent(new CustomEvent('openLeadForm'))"
            class="min-w-[260px]"
          >
            {t.hero.ctaPrimary}
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </Button>
          <Button 
            variant="secondary" 
            size="lg"
            href="tel:+41764218425"
            class="min-w-[260px]"
            magnetic={false}
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            {t.hero.ctaSecondary}
          </Button>
        </div>
      </div>

      <!-- Right: Testimonial & stats -->
      <div class="lg:col-span-5 space-y-6">
        <!-- Testimonial card -->
        <div class="reveal reveal-delay-3 glass-strong rounded-2xl p-8 relative overflow-hidden">
          <div class="absolute top-0 right-0 w-32 h-32 bg-accent/10 rounded-full blur-3xl"></div>
          <div class="flex gap-1 mb-4">
            {[...Array(5)].map(() => (
              <svg class="w-4 h-4 text-yellow-500" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            ))}
          </div>
          <p class="text-text-primary italic mb-4 leading-relaxed">{t.hero.testimonial}</p>
          <p class="text-text-muted text-sm font-medium">{t.hero.testimonialAuthor}</p>
        </div>

        <!-- Trust stats -->
        <div class="stagger-children grid grid-cols-3 gap-4">
          <div class="text-center p-4">
            <p class="text-2xl md:text-3xl font-display text-accent">50+</p>
            <p class="text-text-muted text-xs mt-1">{lang === 'de' ? 'Kunden' : 'Clients'}</p>
          </div>
          <div class="text-center p-4">
            <p class="text-2xl md:text-3xl font-display text-accent">340%</p>
            <p class="text-text-muted text-xs mt-1">{lang === 'de' ? 'Ø ROI' : 'Avg ROI'}</p>
          </div>
          <div class="text-center p-4">
            <p class="text-2xl md:text-3xl font-display text-accent">120</p>
            <p class="text-text-muted text-xs mt-1">{lang === 'de' ? 'Tage' : 'Days'}</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  {/* Scroll indicator */}
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-3">
    <span class="text-text-muted text-xs uppercase tracking-[0.3em]">{lang === 'de' ? 'Scrollen' : 'Scroll'}</span>
    <div class="w-5 h-8 border border-text-muted/30 rounded-full flex justify-center pt-2">
      <div class="w-1 h-2 bg-accent rounded-full animate-bounce"></div>
    </div>
  </div>
</section>

{/* Sticky bottom CTA for mobile */}
<div class="fixed bottom-0 left-0 right-0 z-40 bg-bg-primary/90 backdrop-blur-xl border-t border-white/5 p-4 md:hidden">
  <a 
    href="#audit"
    class="block w-full px-6 py-3 bg-accent text-white text-center font-medium rounded-full hover:bg-accent-hover transition-colors"
    onclick="document.dispatchEvent(new CustomEvent('openLeadForm')); return false;"
  >
    {t.hero.ctaPrimary}
  </a>
</div>
