---
import { getRelativeLocaleUrl } from 'astro:i18n';

const lang = Astro.currentLocale || 'en';

const currentYear = new Date().getFullYear();

const footer = {
  en: {
    tagline: 'Premium SEO & Web Development. Built in Basel.',
    services: 'Services',
    company: 'Company',
    legal: 'Legal',
    contact: 'Contact',
    copyright: `© ${currentYear} buweb.ch. All rights reserved.`
  },
  de: {
    tagline: 'Premium SEO & Webentwicklung. Entwickelt in Basel.',
    services: 'Leistungen',
    company: 'Unternehmen',
    legal: 'Rechtliches',
    contact: 'Kontakt',
    copyright: `© ${currentYear} buweb.ch. Alle Rechte vorbehalten.`
  }
}[lang];
---

<footer class="relative border-t border-white/5 bg-bg-secondary/50">
  <div class="container-custom py-20">
    <div class="grid md:grid-cols-12 gap-12 mb-16">
      <!-- Brand + NAP -->
      <div class="md:col-span-4">
        <a href={getRelativeLocaleUrl(lang, '/')} class="text-2xl font-bold font-body mb-6 block">
          <span class="text-text-primary">buweb</span>
          <span class="text-accent">.ch</span>
        </a>
        <p class="text-text-muted text-sm leading-relaxed max-w-xs mb-6">{footer.tagline}</p>
        
        <!-- NAP Block -->
        <div class="space-y-2 text-sm text-text-muted">
          <p><strong class="text-text-primary">buweb.ch</strong></p>
          <p>Basel, Schweiz</p>
          <p><a href="tel:+41764218425" class="hover:text-accent transition-colors">+41 76 421 84 25</a></p>
          <p><a href="mailto:contact@buweb.ch" class="hover:text-accent transition-colors">contact@buweb.ch</a></p>
        </div>
        </div>
        
        <div class="flex gap-4 mt-8">
          <a href="https://www.linkedin.com/company/buweb-ch" target="_blank" rel="noopener noreferrer" class="w-10 h-10 bg-white/5 border border-white/10 rounded-full flex items-center justify-center text-text-muted hover:text-accent hover:border-accent/50 transition-all duration-300">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <a href="https://github.com/buweb-ch" target="_blank" rel="noopener noreferrer" class="w-10 h-10 bg-white/5 border border-white/10 rounded-full flex items-center justify-center text-text-muted hover:text-accent hover:border-accent/50 transition-all duration-300">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          </a>
        </div>
      </div>
      
      <div class="md:col-span-2 md:col-start-6">
        <h4 class="text-text-primary font-medium mb-6">{footer.services}</h4>
        <ul class="space-y-3">
          <li><a href="#services" class="text-text-muted text-sm hover:text-text-primary transition-colors">{lang === 'de' ? 'SEO Beratung' : 'SEO Consulting'}</a></li>
          <li><a href="#services" class="text-text-muted text-sm hover:text-text-primary transition-colors">{lang === 'de' ? 'Webentwicklung' : 'Web Development'}</a></li>
          <li><a href="#services" class="text-text-muted text-sm hover:text-text-primary transition-colors">{lang === 'de' ? 'Performance' : 'Performance'}</a></li>
          <li><a href="#services" class="text-text-muted text-sm hover:text-text-primary transition-colors">{lang === 'de' ? 'Analytics' : 'Analytics'}</a></li>
        </ul>
      </div>
      
      <div class="md:col-span-2">
        <h4 class="text-text-primary font-medium mb-6">{footer.company}</h4>
        <ul class="space-y-3">
          <li><a href="#process" class="text-text-muted text-sm hover:text-text-primary transition-colors">{lang === 'de' ? 'Prozess' : 'Process'}</a></li>
          <li><a href="#pricing" class="text-text-muted text-sm hover:text-text-primary transition-colors">{lang === 'de' ? 'Preise' : 'Pricing'}</a></li>
          <li><a href="#faq" class="text-text-muted text-sm hover:text-text-primary transition-colors">{lang === 'de' ? 'FAQ' : 'FAQ'}</a></li>
        </ul>
      </div>
      
      <div class="md:col-span-2">
        <h4 class="text-text-primary font-medium mb-6">{footer.legal}</h4>
        <ul class="space-y-3">
          <li><a href={getRelativeLocaleUrl(lang, '/privacy')} class="text-text-muted text-sm hover:text-text-primary transition-colors">{lang === 'de' ? 'Datenschutz' : 'Privacy'}</a></li>
          <li><a href={getRelativeLocaleUrl(lang, '/terms')} class="text-text-muted text-sm hover:text-text-primary transition-colors">{lang === 'de' ? 'AGB' : 'Terms'}</a></li>
          <li><a href={getRelativeLocaleUrl(lang, '/impressum')} class="text-text-muted text-sm hover:text-text-primary transition-colors">{lang === 'de' ? 'Impressum' : 'Legal Notice'}</a></li>
        </ul>
      </div>
    </div>
    
    <div class="border-t border-white/5 pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-text-muted text-sm">{footer.copyright}</p>
      <a href="https://buweb.ch" class="text-text-muted text-sm hover:text-accent transition-colors">buweb.ch</a>
    </div>
  </div>
</footer>